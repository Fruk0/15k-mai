<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Plan 15K — Objetivo 5:40/km</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<style>
  :root {
    --coral:#D85A30;--coral-mid:#F0997B;--coral-light:#FAECE7;--coral-dark:#993C1D;
    --teal:#1D9E75;--teal-mid:#5DCAA5;--teal-light:#E1F5EE;--teal-dark:#0F6E56;
    --amber:#BA7517;--amber-light:#FAEEDA;--amber-mid:#EF9F27;
    --purple:#534AB7;--purple-light:#EEEDFE;
    --gray-50:#F8F7F3;--gray-100:#F1EFE8;--gray-200:#D3D1C7;
    --gray-400:#888780;--gray-600:#5F5E5A;--gray-800:#2C2C2A;
    --bg:#FDFCF9;--text:#1A1A18;--muted:#6B6A66;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);line-height:1.5;padding-bottom:5rem;}

  /* HERO */
  .hero{background:var(--gray-800);color:white;padding:2.5rem 1.5rem 2rem;position:relative;overflow:hidden;}
  .hero::before{content:'15K';font-family:'Bebas Neue',sans-serif;font-size:52vw;position:absolute;right:-6vw;top:-4rem;opacity:0.06;line-height:1;pointer-events:none;color:white;}
  .hero-eyebrow{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--coral-mid);margin-bottom:.3rem;font-weight:500;}
  .hero-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(3.5rem,14vw,6rem);line-height:.9;letter-spacing:.02em;color:white;margin-bottom:1.2rem;}
  .hero-title em{color:var(--coral-mid);font-style:normal;}
  .hero-chips{display:flex;flex-wrap:wrap;gap:6px;margin-top:.75rem;}
  .hero-chip{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:99px;padding:5px 12px;font-size:12px;color:rgba(255,255,255,.7);}
  .hero-chip strong{color:white;font-weight:500;}

  /* PROGRESS */
  .progress-bar-wrap{background:white;border-bottom:1.5px solid var(--gray-100);padding:.9rem 1.5rem;position:sticky;top:0;z-index:100;display:flex;align-items:center;gap:12px;}
  .prog-track{flex:1;height:6px;background:var(--gray-100);border-radius:99px;overflow:hidden;}
  .prog-fill{height:100%;background:linear-gradient(90deg,var(--teal),var(--coral));border-radius:99px;transition:width .4s cubic-bezier(.4,0,.2,1);min-width:0;}
  .prog-label{font-size:13px;font-weight:500;color:var(--muted);white-space:nowrap;}
  .prog-label span{color:var(--coral);}

  /* PACES */
  .paces-section{padding:1.25rem 1.5rem;background:var(--gray-800);border-bottom:1px solid #3a3a38;}
  .eyebrow{font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-bottom:.75rem;}
  .paces-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;}
  @media(min-width:480px){.paces-grid{grid-template-columns:repeat(4,1fr);}}
  .pc{border-radius:10px;padding:10px 12px;border:1px solid;}
  .pc-s{background:#0A2E22;border-color:#1D9E7540;}
  .pc-t{background:#2E1408;border-color:#D85A3040;}
  .pc-c{background:#2E0E04;border-color:#99180D40;}
  .pc-f{background:#18154A;border-color:#534AB740;}
  .pc-name{font-size:10px;letter-spacing:.1em;text-transform:uppercase;margin-bottom:2px;}
  .pc-s .pc-name{color:var(--teal-mid);}
  .pc-t .pc-name{color:var(--coral-mid);}
  .pc-c .pc-name{color:#F09595;}
  .pc-f .pc-name{color:#AFA9EC;}
  .pc-val{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:.05em;line-height:1;}
  .pc-s .pc-val{color:var(--teal-mid);}
  .pc-t .pc-val{color:var(--coral-mid);}
  .pc-c .pc-val{color:#F09595;}
  .pc-f .pc-val{color:#AFA9EC;}
  .pc-range{font-size:11px;margin-top:1px;opacity:.45;color:white;}

  /* WEEKS */
  .weeks-wrap{padding:1.25rem 1.25rem 0;}
  .outer-label{font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:.75rem;padding:0 .25rem;}

  .week-card{margin-bottom:10px;border-radius:16px;border:1.5px solid var(--gray-200);overflow:hidden;background:white;}
  .week-card.descarga{border-color:#F0D49A;}
  .week-card.raceweek{border-color:var(--coral-mid);}

  .week-hdr{padding:13px 16px;display:flex;justify-content:space-between;align-items:center;cursor:pointer;user-select:none;background:var(--gray-50);border-bottom:1.5px solid var(--gray-200);-webkit-tap-highlight-color:transparent;}
  .week-card.descarga .week-hdr{background:#FEF6E4;border-color:#F0D49A;}
  .week-card.raceweek .week-hdr{background:var(--coral-light);border-color:var(--coral-mid);}
  .week-hdr-l{display:flex;align-items:center;gap:8px;}
  .wk-num{font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:.04em;color:var(--gray-800);line-height:1;}
  .week-card.descarga .wk-num{color:#634006;}
  .week-card.raceweek .wk-num{color:var(--coral-dark);}
  .wk-pill{font-size:10px;padding:3px 8px;border-radius:99px;font-weight:500;letter-spacing:.04em;}
  .pill-n{background:var(--gray-200);color:var(--gray-600);}
  .pill-d{background:#FAC775;color:#412402;}
  .pill-r{background:var(--coral);color:white;}
  .wk-chev{color:var(--gray-400);font-size:16px;transition:transform .22s;line-height:1;}
  .week-card.open .wk-chev{transform:rotate(180deg);}
  .week-days{display:none;}
  .week-card.open .week-days{display:block;}

  /* DAY */
  .day-item{padding:14px 16px;border-bottom:1px solid var(--gray-100);display:flex;gap:10px;align-items:flex-start;}
  .day-item:last-child{border-bottom:none;}
  .day-check{width:26px;height:26px;border-radius:50%;border:1.5px solid var(--gray-200);flex-shrink:0;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;margin-top:2px;background:white;-webkit-tap-highlight-color:transparent;font-size:13px;font-weight:700;}
  .day-check.done{background:var(--teal);border-color:var(--teal);color:white;}
  .day-check.done::after{content:'✓';}
  .day-body{flex:1;min-width:0;}
  .day-hdr{display:flex;align-items:center;gap:6px;margin-bottom:8px;flex-wrap:wrap;}
  .day-name{font-size:12px;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);}
  .dtag{font-size:10px;padding:2px 7px;border-radius:5px;font-weight:500;text-transform:uppercase;letter-spacing:.07em;}
  .t-fondo{background:var(--teal-light);color:var(--teal-dark);}
  .t-int{background:var(--purple-light);color:var(--purple);}
  .t-tempo{background:var(--coral-light);color:var(--coral-dark);}
  .t-suave{background:var(--gray-100);color:var(--gray-600);}
  .t-prog{background:var(--amber-light);color:#634006;}
  .t-carrera{background:var(--coral);color:white;}

  /* WORKOUT */
  .wk-wrap{display:flex;flex-direction:column;gap:5px;}

  /* Step row */
  .srow{display:flex;align-items:center;gap:8px;background:var(--gray-50);border-radius:9px;padding:8px 11px;border-left:3px solid var(--gray-200);}
  .srow.wu,.srow.cd{border-left-color:var(--teal-mid);}
  .srow.run{border-left-color:var(--coral);}
  .srow.jog{border-left-color:var(--teal);}
  .slabel{font-size:12px;color:var(--muted);flex:1;min-width:0;}
  .slabel strong{color:var(--text);font-weight:500;}
  .space{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:.04em;flex-shrink:0;}
  .sp-c{color:var(--coral);}
  .sp-t{color:var(--teal);}
  .sp-p{color:var(--purple);}
  .sp-a{color:var(--amber);}
  .srange{font-size:10px;color:var(--muted);flex-shrink:0;}

  /* Interval set */
  .iset{background:var(--gray-50);border-radius:11px;overflow:hidden;border:1.5px solid var(--gray-100);}
  .iset-hdr{padding:6px 11px;font-size:11px;font-weight:500;letter-spacing:.06em;text-transform:uppercase;color:var(--muted);background:var(--gray-100);border-bottom:1px solid var(--gray-200);}
  .irow{display:flex;align-items:stretch;border-bottom:1px solid var(--gray-100);}
  .irow:last-child{border-bottom:none;}
  .ibar{width:4px;flex-shrink:0;}
  .ibar-r{background:var(--coral);}
  .ibar-j{background:var(--teal);}
  .ibar-w{background:var(--amber-mid);}
  .ibody{flex:1;padding:8px 11px;display:flex;align-items:center;justify-content:space-between;gap:8px;}
  .itype{font-size:12px;font-weight:500;}
  .it-r{color:var(--coral-dark);}
  .it-j{color:var(--teal-dark);}
  .it-w{color:var(--amber);}
  .idur{font-size:12px;color:var(--muted);}
  .ipace-wrap{text-align:right;}
  .ipace{font-family:'Bebas Neue',sans-serif;font-size:1.15rem;letter-spacing:.04em;display:block;}
  .irange{font-size:10px;color:var(--muted);display:block;}

  /* Progression */
  .prog-wrap{background:var(--gray-50);border-radius:11px;overflow:hidden;border:1.5px solid var(--gray-100);}
  .prog-hdr{padding:6px 11px;font-size:11px;font-weight:500;letter-spacing:.06em;text-transform:uppercase;color:var(--muted);background:var(--gray-100);border-bottom:1px solid var(--gray-200);}
  .prow{display:flex;align-items:center;padding:8px 11px;gap:10px;border-bottom:1px solid var(--gray-100);}
  .prow:last-child{border-bottom:none;}
  .pdot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
  .pkm{font-size:12px;color:var(--muted);min-width:72px;}
  .parrow{color:var(--gray-200);font-size:12px;}
  .ppace{font-family:'Bebas Neue',sans-serif;font-size:1.15rem;letter-spacing:.04em;}
  .prange{font-size:10px;color:var(--muted);margin-left:auto;}

  /* RACE CARD */
  .race-card{margin:0 1.25rem 1rem;background:var(--gray-800);border-radius:16px;padding:1.5rem;color:white;position:relative;overflow:hidden;}
  .race-card::after{content:'🏁';font-size:9rem;position:absolute;right:-1.5rem;bottom:-2rem;opacity:.07;}
  .race-ey{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--coral-mid);margin-bottom:4px;}
  .race-title{font-family:'Bebas Neue',sans-serif;font-size:2.2rem;letter-spacing:.04em;line-height:1;margin-bottom:1.1rem;}
  .race-segs{display:flex;flex-direction:column;gap:6px;}
  .rseg{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:9px;padding:9px 13px;display:flex;justify-content:space-between;align-items:center;}
  .rseg-km{font-size:12px;color:rgba(255,255,255,.55);}
  .rseg-pace{font-family:'Bebas Neue',sans-serif;font-size:1.25rem;letter-spacing:.05em;color:var(--coral-mid);}

  /* TIPS */
  .tips-card{margin:0 1.25rem 1rem;background:var(--teal-light);border-radius:16px;padding:1.1rem 1.25rem;border:1.5px solid #9FE1CB;}
  .tips-ttl{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--teal-dark);font-weight:500;margin-bottom:8px;}
  .tips-list{list-style:none;display:flex;flex-direction:column;gap:5px;}
  .tips-list li{font-size:13px;color:var(--teal-dark);padding-left:14px;position:relative;line-height:1.45;}
  .tips-list li::before{content:'—';position:absolute;left:0;color:var(--teal);}

  /* MOTO */
  .moto{padding:2rem 1.5rem 1rem;text-align:center;}
  .moto-t{font-family:'Bebas Neue',sans-serif;font-size:clamp(2rem,9vw,3.8rem);letter-spacing:.03em;color:var(--gray-800);line-height:1.05;}
  .moto-t em{color:var(--coral);font-style:normal;}
</style>
</head>
<body>

<div class="hero">
  <p class="hero-eyebrow">Objetivo personal</p>
  <h1 class="hero-title">Plan<br><em>15K</em></h1>
  <div class="hero-chips">
    <span class="hero-chip"><strong>Inicio</strong> 24 mar 2026</span>
    <span class="hero-chip"><strong>Carrera</strong> 07 jun 2026</span>
    <span class="hero-chip"><strong>Objetivo</strong> 5:40/km — 1h25</span>
    <span class="hero-chip"><strong>Días</strong> Lun · Mié · Sáb</span>
  </div>
</div>

<div class="progress-bar-wrap">
  <div class="prog-track"><div class="prog-fill" id="pf" style="width:0%"></div></div>
  <div class="prog-label"><span id="pd">0</span> / 30</div>
</div>

<div class="paces-section">
  <p class="eyebrow">Ritmos de referencia</p>
  <div class="paces-grid">
    <div class="pc pc-s"><div class="pc-name">Suave · fondo</div><div class="pc-val">6:30</div><div class="pc-range">6:15–6:50 /km</div></div>
    <div class="pc pc-t"><div class="pc-name">Tempo</div><div class="pc-val">5:40</div><div class="pc-range">5:35–5:45 /km</div></div>
    <div class="pc pc-c"><div class="pc-name">Ritmo carrera</div><div class="pc-val">5:40</div><div class="pc-range">5:35–5:45 /km</div></div>
    <div class="pc pc-f"><div class="pc-name">Fuerte · intervalos</div><div class="pc-val">5:10</div><div class="pc-range">5:00–5:20 /km</div></div>
  </div>
</div>

<div class="weeks-wrap">
<p class="outer-label">Plan semana a semana</p>

<!-- helpers: irow(bar,type,label,dur,pace,range) -->

<!-- S1 -->
<div class="week-card" id="w1">
  <div class="week-hdr" onclick="tw('w1')"><div class="week-hdr-l"><span class="wk-num">Semana 1</span><span class="wk-pill pill-n">24–28 mar</span></div><span class="wk-chev">▾</span></div>
  <div class="week-days">
    <div class="day-item"><div class="day-check" onclick="td(this)"></div><div class="day-body">
      <div class="day-hdr"><span class="day-name">Lunes</span><span class="dtag t-tempo">Tempo</span></div>
      <div class="wk-wrap">
        <div class="srow wu"><span class="slabel"><strong>Entrada en calor</strong></span><span class="space sp-t">6:30</span><span class="srange">10'</span></div>
        <div class="iset"><div class="iset-hdr">6 series</div>
          <div class="irow"><div class="ibar ibar-r"></div><div class="ibody"><span class="itype it-r">🏃 Correr</span><span class="idur">2:00</span><div class="ipace-wrap"><span class="ipace sp-c">5:40</span><span class="irange">5:35–5:45</span></div></div></div>
          <div class="irow"><div class="ibar ibar-j"></div><div class="ibody"><span class="itype it-j">🚶 Trotar</span><span class="idur">2:00</span><div class="ipace-wrap"><span class="ipace sp-t">6:30</span><span class="irange">6:15–6:50</span></div></div></div>
        </div>
        <div class="srow cd"><span class="slabel"><strong>Vuelta a la calma</strong></span><span class="space sp-t">6:40</span><span class="srange">10'</span></div>
      </div>
    </div></div>
    <div class="day-item"><div class="day-check" onclick="td(this)"></div><div class="day-body">
      <div class="day-hdr"><span class="day-name">Miércoles</span><span class="dtag t-suave">Continuo</span></div>
      <div class="wk-wrap">
        <div class="srow wu"><span class="slabel"><strong>Entrada en calor</strong></span><span class="space sp-t">6:30</span><span class="srange">10'</span></div>
        <div class="iset"><div class="iset-hdr">3 series</div>
          <div class="irow"><div class="ibar ibar-r"></div><div class="ibody"><span class="itype it-r">🏃 Correr</span><span class="idur">5:00</span><div class="ipace-wrap"><span class="ipace sp-c">6:00</span><span class="irange">5:50–6:10</span></div></div></div>
          <div class="irow"><div class="ibar ibar-j"></div><div class="ibody"><span class="itype it-j">🚶 Trotar</span><span class="idur">3:00</span><div class="ipace-wrap"><span class="ipace sp-t">6:30</span><span class="irange">6:15–6:50</span></div></div></div>
        </div>
        <div class="srow run"><span class="slabel"><strong>Continuar suave</strong> hasta completar 45' total</span><span class="space sp-t">6:30</span></div>
      </div>
    </div></div>
    <div class="day-item"><div class="day-check" onclick="td(this)"></div><div class="day-body">
      <div class="day-hdr"><span class="day-name">Sábado</span><span class="dtag t-fondo">Fondo</span></div>
      <div class="wk-wrap"><div class="srow run"><span class="slabel"><strong>10 km</strong> continuo</span><span class="space sp-t">6:30</span><span class="srange">6:15–6:50</span></div></div>
    </div></div>
  </div>
</div>

<!-- S2 -->
<div class="week-card" id="w2">
  <div class="week-hdr" onclick="tw('w2')"><div class="week-hdr-l"><span class="wk-num">Semana 2</span><span class="wk-pill pill-n">30 mar–4 abr</span></div><span class="wk-chev">▾</span></div>
  <div class="week-days">
    <div class="day-item"><div class="day-check" onclick="td(this)"></div><div class="day-body">
      <div class="day-hdr"><span class="day-name">Lunes</span><span class="dtag t-tempo">Tempo</span></div>
      <div class="wk-wrap">
        <div class="srow wu"><span class="slabel"><strong>Entrada en calor</strong></span><span class="space sp-t">6:30</span><span class="srange">10'</span></div>
        <div class="iset"><div class="iset-hdr">5 series</div>
          <div class="irow"><div class="ibar ibar-r"></div><div class="ibody"><span class="itype it-r">🏃 Correr</span><span class="idur">3:00</span><div class="ipace-wrap"><span class="ipace sp-c">5:40</span><span class="irange">5:35–5:45</span></div></div></div>
          <div class="irow"><div class="ibar ibar-j"></div><div class="ibody"><span class="itype it-j">🚶 Trotar</span><span class="idur">2:00</span><div class="ipace-wrap"><span class="ipace sp-t">6:30</span><span class="irange">suave</span></div></div></div>
        </div>
        <div class="srow cd"><span class="slabel"><strong>Vuelta a la calma</strong></span><span class="space sp-t">6:40</span><span class="srange">10'</span></div>
      </div>
    </div></div>
    <div class="day-item"><div class="day-check" onclick="td(this)"></div><div class="day-body">
      <div class="day-hdr"><span class="day-name">Miércoles</span><span class="dtag t-suave">Fondo + strides</span></div>
      <div class="wk-wrap">
        <div class="srow run"><span class="slabel"><strong>Trote</strong> continuo</span><span class="space sp-t">6:30</span><span class="srange">40'</span></div>
        <div class="iset"><div class="iset-hdr">4 strides</div>
          <div class="irow"><div class="ibar ibar-r"></div><div class="ibody"><span class="itype it-r">🏃 Correr fuerte</span><span class="idur">0:20</span><div class="ipace-wrap"><span class="ipace sp-p">4:50</span><span class="irange">4:40–5:00</span></div></div></div>
          <div class="irow"><div class="ibar ibar-w"></div><div class="ibody"><span class="itype it-w">🚶 Caminar / trotar</span><span class="idur">1:00</span><div class="ipace-wrap"><span class="ipace sp-a">—</span><span class="irange">recuperar</span></div></div></div>
        </div>
      </div>
    </div></div>
    <div class="day-item"><div class="day-check" onclick="td(this)"></div><div class="day-body">
      <div class="day-hdr"><span class="day-name">Sábado</span><span class="dtag t-prog">Fondo progresivo</span></div>
      <div class="wk-wrap"><div class="prog-wrap"><div class="prog-hdr">11 km progresivos</div>
        <div class="prow"><span class="pdot" style="background:var(--teal)"></span><span class="pkm">Km 1 – 9</span><span class="parrow">→</span><span class="ppace sp-t">6:30</span><span class="prange">6:15–6:50</span></div>
        <div class="prow"><span class="pdot" style="background:var(--coral)"></span><span class="pkm">Km 10 – 11</span><span class="parrow">→</span><span class="ppace sp-c">6:00</span><span class="prange">5:50–6:10</span></div>
      </div></div>
    </div></div>
  </div>
</div>

<!-- S3 -->
<div class="week-card" id="w3">
  <div class="week-hdr" onclick="tw('w3')"><div class="week-hdr-l"><span class="wk-num">Semana 3</span><span class="wk-pill pill-n">6–11 abr</span></div><span class="wk-chev">▾</span></div>
  <div class="week-days">
    <div class="day-item"><div class="day-check" onclick="td(this)"></div><div class="day-body">
      <div class="day-hdr"><span class="day-name">Lunes</span><span class="dtag t-tempo">Tempo</span></div>
      <div class="wk-wrap">
        <div class="srow wu"><span class="slabel"><strong>Entrada en calor</strong></span><span class="space sp-t">6:30</span><span class="srange">10'</span></div>
        <div class="iset"><div class="iset-hdr">4 series</div>
          <div class="irow"><div class="ibar ibar-r"></div><div class="ibody"><span class="itype it-r">🏃 Correr</span><span class="idur">5:00</span><div class="ipace-wrap"><span class="ipace sp-c">5:40</span><span class="irange">5:35–5:45</span></div></div></div>
