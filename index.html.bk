<!-- RACE -->
<div class="race-card" style="margin-top:1.25rem">
  <p class="race-ey">Domingo 07 de junio de 2026</p>
  <p class="race-title">Carrera 15K</p>
  <div class="race-segs">
    <div class="rseg"><span class="rseg-km">Km 1–3 · Salida controlada</span><span class="rseg-pace">5:45</span></div>
    <div class="rseg"><span class="rseg-km">Km 4–10 · Ritmo crucero</span><span class="rseg-pace">5:40</span></div>
    <div class="rseg"><span class="rseg-km">Km 11–15 · Si hay resto ↗</span><span class="rseg-pace">5:35</span></div>
  </div>
</div>

<!-- TIPS -->
<div class="tips-card">
  <p class="tips-ttl">Claves del plan</p>
  <ul class="tips-list">
    <li>Tempo y ritmo carrera son iguales a propósito — el progreso es sostenerlo más tiempo</li>
    <li>El fondo construye la base — no se corre fuerte</li>
    <li>Si hay duda, elegí siempre el ritmo más lento del rango</li>
    <li>La semana 7 es de descarga — no saltear, es parte del plan</li>
    <li>Los últimos 3 días antes de carrera: piernas descansadas</li>
  </ul>
</div>

<!-- MOTO -->
<div class="moto">
  <p class="moto-t">Cada kilómetro<br>te acerca al <em>7 de junio</em></p>
</div>

<script>
const SK='plan15k_v2';
function ld(){try{return JSON.parse(localStorage.getItem(SK))||{};}catch(e){return{};}}
function sv(d){try{localStorage.setItem(SK,JSON.stringify(d));}catch(e){}}
function ub(){
  var all=document.querySelectorAll('.day-check');
  var done=document.querySelectorAll('.day-check.done').length;
  document.getElementById('pd').textContent=done;
  document.getElementById('pf').style.width=Math.round(done/all.length*100)+'%';
}
function td(el){
  var d=ld();
  var idx=Array.from(document.querySelectorAll('.day-check')).indexOf(el);
  el.classList.toggle('done');
  if(el.classList.contains('done'))d[idx]=1;else delete d[idx];
  sv(d);ub();
}
function tw(id){document.getElementById(id).classList.toggle('open');}
(function(){
  var d=ld();
  document.querySelectorAll('.day-check').forEach(function(el,i){if(d[i])el.classList.add('done');});
  document.getElementById('w1').classList.add('open');
  ub();
})();
</script>
</body>
</html>
