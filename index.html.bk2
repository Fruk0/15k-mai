      <div class="wkwrap">
        <div class="srow wu"><span class="slabel"><strong>Entrada en calor</strong></span><span class="sdur">10 min</span><span class="space sp-g">6:30</span></div>
        <div class="iset"><div class="iset-hdr">2 series</div>
          <div class="irow"><div class="ibar ibar-r"></div><div class="ibody"><span class="itype it-r">Correr</span><span class="idur">1 km</span><div class="ipace-wrap"><span class="ipace sp-b">5:40</span><span class="irange">5:35–5:45</span></div></div></div>
          <div class="irow"><div class="ibar ibar-j"></div><div class="ibody"><span class="itype it-j">Trotar</span><span class="idur">3:00 min</span><div class="ipace-wrap"><span class="ipace sp-g">6:30</span><span class="irange">suave</span></div></div></div>
        </div>
        <div class="srow cd"><span class="slabel"><strong>Vuelta a la calma</strong></span><span class="sdur">10 min</span><span class="space sp-g">6:40</span></div>
      </div>
    </div></div>
    <div class="ditem"><div class="dcheck" onclick="td(this)"></div><div class="dbody">
      <div class="dhdr"><span class="dname">Sábado</span><span class="dtag t-suave">Trote suave</span></div>
      <div class="wkwrap"><div class="srow run"><span class="slabel"><strong>Piernas descansadas</strong></span><span class="sdur">20 min</span><span class="space sp-g">6:40</span></div></div>
    </div></div>
  </div>
</div>

</div><!-- /weeks -->

<!-- RACE -->
<div class="race-card" style="margin-top:1rem">
  <p class="race-ey">Domingo 07 de junio de 2026</p>
  <p class="race-title">CARRERA 15K</p>
  <div class="race-segs">
    <div class="rseg"><span class="rseg-km">Km 1–3 · Salida controlada</span><span class="rseg-pace">5:45 /km</span></div>
    <div class="rseg"><span class="rseg-km">Km 4–10 · Ritmo crucero</span><span class="rseg-pace">5:40 /km</span></div>
    <div class="rseg"><span class="rseg-km">Km 11–15 · Si hay resto ↗</span><span class="rseg-pace">5:35 /km</span></div>
  </div>
</div>

<!-- TIPS -->
<div class="tips-card">
  <p class="tips-ttl">Claves</p>
  <ul class="tips-list">
    <li>Tempo y ritmo carrera son iguales a propósito — el progreso es sostenerlo más tiempo</li>
    <li>El fondo construye la base — no se corre fuerte</li>
    <li>Si hay duda, elegí siempre el ritmo más lento del rango</li>
    <li>La semana 7 es de descarga — no saltear, es parte del plan</li>
    <li>Los últimos 3 días antes de carrera: piernas descansadas</li>
  </ul>
</div>

<!-- MOTO -->
<div class="moto">
  <p class="moto-t">Cada km<br>te acerca al<br><em>7 de junio</em></p>
</div>

<script>
const SK='plan15k_v3';
function ld(){try{return JSON.parse(localStorage.getItem(SK))||{};}catch(e){return{};}}
function sv(d){try{localStorage.setItem(SK,JSON.stringify(d));}catch(e){}}
function ub(){
  var all=document.querySelectorAll('.dcheck');
  var done=document.querySelectorAll('.dcheck.done').length;
  document.getElementById('pd').textContent=done;
  document.getElementById('pf').style.width=Math.round(done/all.length*100)+'%';
}
function td(el){
  var d=ld(),idx=Array.from(document.querySelectorAll('.dcheck')).indexOf(el);
  el.classList.toggle('done');
  if(el.classList.contains('done'))d[idx]=1;else delete d[idx];
  sv(d);ub();
}
function tw(id){document.getElementById(id).classList.toggle('open');}
(function(){
  var d=ld();
  document.querySelectorAll('.dcheck').forEach(function(el,i){if(d[i])el.classList.add('done');});
  document.getElementById('w1').classList.add('open');
  ub();
})();
</script>
</body>
</html>
