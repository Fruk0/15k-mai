<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Plan 15K</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg:       #141414;
  --bg2:      #1C1C1C;
  --bg3:      #222222;
  --border:   #2A2A2A;
  --border2:  #333333;

  --text:     #F0F0EE;
  --muted:    #666660;
  --dim:      #3A3A38;

  --violet:   #8B7CF6;
  --violet-d: #6D5DE0;
  --violet-bg:#1E1A36;

  --blue:     #5BA4F5;
  --blue-d:   #3D86E0;
  --blue-bg:  #151E30;

  --green:    #3EC98E;
  --green-d:  #28A872;
  --green-bg: #0F2820;

  --amber:    #F5A623;
  --amber-bg: #271E0A;

  --red:      #F56565;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Space Grotesk', sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.5;
  padding-bottom: 5rem;
  -webkit-font-smoothing: antialiased;
}

/* ── HERO ── */
.hero {
  padding: 3rem 1.5rem 2.5rem;
  border-bottom: 1px solid var(--border);
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '15K';
  font-family: 'Space Mono', monospace;
  font-size: 46vw;
  position: absolute;
  right: -4vw;
  top: -2rem;
  line-height: 1;
  opacity: 0.03;
  color: var(--violet);
  pointer-events: none;
  letter-spacing: -0.05em;
}
.hero-eyebrow {
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--violet);
  margin-bottom: 0.6rem;
  font-weight: 500;
}
.hero-title {
  font-family: 'Space Mono', monospace;
  font-size: clamp(3rem, 13vw, 5.5rem);
  font-weight: 700;
  line-height: 0.92;
  color: var(--text);
  letter-spacing: -0.03em;
  margin-bottom: 0.3rem;
}
.hero-sub {
  font-family: 'Space Mono', monospace;
  font-size: clamp(1rem, 4vw, 1.5rem);
  color: var(--green);
  font-weight: 400;
  letter-spacing: 0.02em;
  margin-bottom: 1.75rem;
}
.hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.meta-chip {
  font-size: 12px;
  padding: 4px 10px;
  border-radius: 4px;
  border: 1px solid var(--border2);
  color: var(--muted);
  background: var(--bg2);
}
.meta-chip strong { color: var(--text); font-weight: 500; }

/* ── PROGRESS ── */
.prog-bar {
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  padding: 0.85rem 1.5rem;
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 14px;
}
.prog-track {
  flex: 1;
  height: 2px;
  background: var(--border2);
  border-radius: 99px;
  overflow: hidden;
}
.prog-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--violet), var(--green));
  border-radius: 99px;
  transition: width 0.4s ease;
  min-width: 0;
}
.prog-label {
  font-family: 'Space Mono', monospace;
  font-size: 12px;
  color: var(--muted);
  white-space: nowrap;
}
.prog-label span { color: var(--violet); }

/* ── PACES ── */
.paces {
  padding: 1.5rem;
  border-bottom: 1px solid var(--border);
  background: var(--bg);
}
.section-label {
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 1rem;
}
.paces-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 6px;
}
@media(min-width:480px){ .paces-grid { grid-template-columns: repeat(4,1fr); } }

.pace-tile {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 12px;
}
.pace-tile-name {
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 4px;
}
.pace-tile-val {
  font-family: 'Space Mono', monospace;
  font-size: 1.5rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1;
}
.pace-tile-range {
  font-size: 10px;
  margin-top: 3px;
  opacity: 0.4;
}
.pt-v .pace-tile-name { color: var(--violet); }
.pt-v .pace-tile-val  { color: var(--violet); }
.pt-b .pace-tile-name { color: var(--blue); }
.pt-b .pace-tile-val  { color: var(--blue); }
.pt-g .pace-tile-name { color: var(--green); }
.pt-g .pace-tile-val  { color: var(--green); }
.pt-a .pace-tile-name { color: var(--amber); }
.pt-a .pace-tile-val  { color: var(--amber); }

/* ── WEEKS ── */
.weeks { padding: 1rem 1rem 0; }
.weeks-label {
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 0.75rem;
  padding: 0 0.25rem;
}

.wcard {
  margin-bottom: 6px;
  border-radius: 10px;
  border: 1px solid var(--border);
  overflow: hidden;
  background: var(--bg2);
}
.wcard.descarga { border-color: #3A2E0A; }
.wcard.raceweek { border-color: var(--violet-d); }

.whdr {
  padding: 11px 14px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  user-select: none;
  background: var(--bg3);
  border-bottom: 1px solid var(--border);
  -webkit-tap-highlight-color: transparent;
}
.wcard.descarga .whdr { background: var(--amber-bg); border-color: #3A2E0A; }
.wcard.raceweek .whdr { background: var(--violet-bg); border-color: #2E2860; }

.whdr-l { display: flex; align-items: center; gap: 8px; }
.wnum {
  font-family: 'Space Mono', monospace;
  font-size: 13px;
  font-weight: 700;
  color: var(--text);
  letter-spacing: 0.02em;
}
.wcard.descarga .wnum { color: var(--amber); }
.wcard.raceweek .wnum { color: var(--violet); }

.wpill {
  font-size: 10px;
  padding: 2px 7px;
  border-radius: 3px;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}
.pill-n { background: var(--border2); color: var(--muted); }
.pill-d { background: #3A2E0A; color: var(--amber); }
.pill-r { background: var(--violet-d); color: white; }

.wchev {
  color: var(--dim);
  font-size: 14px;
  transition: transform .2s;
  line-height: 1;
}
.wcard.open .wchev { transform: rotate(180deg); }
.wdays { display: none; }
.wcard.open .wdays { display: block; }

/* ── DAY ── */
.ditem {
  padding: 14px;
  border-bottom: 1px solid var(--border);
  display: flex;
  gap: 10px;
  align-items: flex-start;
}
.ditem:last-child { border-bottom: none; }

.dcheck {
  width: 22px; height: 22px;
  border-radius: 50%;
  border: 1px solid var(--border2);
  flex-shrink: 0;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: all .2s;
  margin-top: 2px;
  background: transparent;
  -webkit-tap-highlight-color: transparent;
  font-size: 11px;
  font-weight: 700;
  color: transparent;
}
.dcheck.done {
  background: var(--green);
  border-color: var(--green);
  color: var(--bg);
}
.dcheck.done::after { content: '✓'; }

.dbody { flex: 1; min-width: 0; }
.dhdr { display: flex; align-items: center; gap: 7px; margin-bottom: 10px; flex-wrap: wrap; }
.dname {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
}
.dtag {
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 3px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.07em;
}
.t-fondo    { background: var(--green-bg);  color: var(--green); }
.t-int      { background: var(--violet-bg); color: var(--violet); }
.t-tempo    { background: var(--blue-bg);   color: var(--blue); }
.t-suave    { background: var(--bg3);       color: var(--muted); }
.t-prog     { background: var(--amber-bg);  color: var(--amber); }
.t-carrera  { background: var(--violet-d);  color: white; }

/* ── WORKOUT ── */
.wkwrap { display: flex; flex-direction: column; gap: 4px; }

/* Step row */
.srow {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--bg3);
  border-radius: 6px;
  padding: 8px 11px;
  border-left: 2px solid var(--border2);
}
.srow.wu, .srow.cd { border-left-color: var(--green); }
.srow.run { border-left-color: var(--blue); }
.slabel { font-size: 12px; color: var(--muted); flex: 1; min-width: 0; }
.slabel strong { color: var(--text); font-weight: 500; }
.space {
  font-family: 'Space Mono', monospace;
  font-size: 13px;
  font-weight: 700;
  flex-shrink: 0;
}
.sp-g { color: var(--green); }
.sp-b { color: var(--blue); }
.sp-v { color: var(--violet); }
.sp-a { color: var(--amber); }
.srange { font-size: 10px; color: var(--muted); flex-shrink: 0; }
.sdur {
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  color: var(--muted);
  flex-shrink: 0;
  border: 1px solid var(--border2);
  border-radius: 3px;
  padding: 1px 5px;
}

/* Interval set */
.iset {
  background: var(--bg3);
  border-radius: 8px;
  overflow: hidden;
  border: 1px solid var(--border);
}
.iset-hdr {
  padding: 5px 11px;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  background: var(--bg);
  border-bottom: 1px solid var(--border);
}
.irow {
  display: flex;
  align-items: stretch;
  border-bottom: 1px solid var(--border);
}
.irow:last-child { border-bottom: none; }
.ibar { width: 2px; flex-shrink: 0; }
.ibar-r { background: var(--blue); }
.ibar-j { background: var(--green); }
.ibar-w { background: var(--amber); }
.ibar-v { background: var(--violet); }
.ibody {
  flex: 1;
  padding: 9px 11px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.itype {
  font-size: 12px;
  font-weight: 500;
  flex: 1;
  min-width: 0;
}
.it-r { color: var(--blue); }
.it-j { color: var(--green); }
.it-w { color: var(--amber); }
.it-v { color: var(--violet); }
.idur {
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  color: var(--muted);
  border: 1px solid var(--border2);
  border-radius: 3px;
  padding: 1px 5px;
  white-space: nowrap;
}
.ipace-wrap { text-align: right; flex-shrink: 0; }
.ipace {
  font-family: 'Space Mono', monospace;
  font-size: 14px;
  font-weight: 700;
  display: block;
  letter-spacing: -0.01em;
}
.irange { font-size: 10px; color: var(--muted); display: block; }

/* Progression */
.progwrap {
  background: var(--bg3);
  border-radius: 8px;
  overflow: hidden;
  border: 1px solid var(--border);
}
.prog-hdr-lbl {
  padding: 5px 11px;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  background: var(--bg);
  border-bottom: 1px solid var(--border);
}
.prow {
  display: flex;
  align-items: center;
  padding: 9px 11px;
  gap: 10px;
  border-bottom: 1px solid var(--border);
}
.prow:last-child { border-bottom: none; }
.pdot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.pkm { font-size: 12px; color: var(--muted); min-width: 68px; }
.parrow { color: var(--border2); font-size: 12px; }
.ppace {
  font-family: 'Space Mono', monospace;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: -0.01em;
}
.prange { font-size: 10px; color: var(--muted); margin-left: auto; }

/* ── RACE ── */
.race-card {
  margin: 0 1rem 0.75rem;
  background: var(--violet-bg);
  border: 1px solid var(--violet-d);
  border-radius: 10px;
  padding: 1.5rem;
  position: relative;
  overflow: hidden;
}
.race-card::after {
  content: '🏁';
  font-size: 8rem;
  position: absolute;
  right: -1rem; bottom: -2rem;
  opacity: 0.06;
}
.race-ey {
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--violet);
  margin-bottom: 4px;
}
.race-title {
  font-family: 'Space Mono', monospace;
  font-size: 1.8rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--text);
  line-height: 1;
  margin-bottom: 1.1rem;
}
.race-segs { display: flex; flex-direction: column; gap: 5px; }
.rseg {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.07);
  border-radius: 6px;
  padding: 8px 12px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.rseg-km { font-size: 12px; color: var(--muted); }
.rseg-pace {
  font-family: 'Space Mono', monospace;
  font-size: 14px;
  font-weight: 700;
  color: var(--violet);
}

/* ── TIPS ── */
.tips-card {
  margin: 0 1rem 0.75rem;
  background: var(--green-bg);
  border: 1px solid #1A4A32;
  border-radius: 10px;
  padding: 1rem 1.25rem;
}
.tips-ttl {
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--green);
  font-weight: 600;
  margin-bottom: 8px;
}
.tips-list { list-style: none; display: flex; flex-direction: column; gap: 6px; }
.tips-list li {
  font-size: 12px;
  color: #7EC9A8;
  padding-left: 14px;
  position: relative;
  line-height: 1.5;
}
.tips-list li::before { content: '—'; position: absolute; left: 0; color: var(--green); }

/* ── MOTO ── */
.moto {
  padding: 2.5rem 1.5rem 1rem;
  text-align: center;
}
.moto-t {
  font-family: 'Space Mono', monospace;
  font-size: clamp(1.4rem, 6vw, 2.5rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--text);
  line-height: 1.15;
}
.moto-t em { color: var(--violet); font-style: normal; }
</style>
</head>
<body>

<!-- HERO -->
<div class="hero">
  <p class="hero-eyebrow">Plan de entrenamiento</p>
  <h1 class="hero-title">PLAN<br>15K</h1>
  <p class="hero-sub">→ 5:40 /km</p>
  <div class="hero-meta">
    <span class="meta-chip"><strong>Inicio</strong> 24 mar 2026</span>
    <span class="meta-chip"><strong>Carrera</strong> 07 jun 2026</span>
    <span class="meta-chip"><strong>Meta</strong> 1h 25min</span>
    <span class="meta-chip"><strong>Días</strong> Lun · Mié · Sáb</span>
  </div>
</div>

<!-- PROGRESS -->
<div class="prog-bar">
  <div class="prog-track"><div class="prog-fill" id="pf" style="width:0%"></div></div>
  <div class="prog-label"><span id="pd">0</span>/30 completados</div>
</div>

<!-- PACES -->
<div class="paces">
  <p class="section-label">Ritmos de referencia</p>
  <div class="paces-grid">
    <div class="pace-tile pt-g">
      <div class="pace-tile-name">Suave · fondo</div>
      <div class="pace-tile-val">6:30</div>
      <div class="pace-tile-range">6:15–6:50 /km</div>
    </div>
    <div class="pace-tile pt-b">
      <div class="pace-tile-name">Tempo</div>
      <div class="pace-tile-val">5:40</div>
      <div class="pace-tile-range">5:35–5:45 /km</div>
    </div>
    <div class="pace-tile pt-b">
      <div class="pace-tile-name">Ritmo carrera</div>
      <div class="pace-tile-val">5:40</div>
      <div class="pace-tile-range">5:35–5:45 /km</div>
    </div>
    <div class="pace-tile pt-v">
      <div class="pace-tile-name">Fuerte · intervalos</div>
      <div class="pace-tile-val">5:10</div>
      <div class="pace-tile-range">5:00–5:20 /km</div>
    </div>
  </div>
</div>

<!-- WEEKS -->
<div class="weeks">
<p class="weeks-label">Semanas</p>

<!-- helpers inline -->
<!-- irow: bar class, type class, label, dur, pace color, pace val, range -->

<!-- S1 -->
<div class="wcard" id="w1">
  <div class="whdr" onclick="tw('w1')"><div class="whdr-l"><span class="wnum">Semana 01</span><span class="wpill pill-n">24–28 mar</span></div><span class="wchev">▾</span></div>
  <div class="wdays">

    <div class="ditem"><div class="dcheck" onclick="td(this)"></div><div class="dbody">
      <div class="dhdr"><span class="dname">Lunes</span><span class="dtag t-tempo">Tempo</span></div>
      <div class="wkwrap">
        <div class="srow wu"><span class="slabel"><strong>Entrada en calor</strong></span><span class="sdur">10 min</span><span class="space sp-g">6:30</span></div>
        <div class="iset"><div class="iset-hdr">6 series</div>
          <div class="irow"><div class="ibar ibar-r"></div><div class="ibody"><span class="itype it-r">Correr</span><span class="idur">2:00 min</span><div class="ipace-wrap"><span class="ipace sp-b">5:40</span><span class="irange">5:35–5:45</span></div></div></div>
          <div class="irow"><div class="ibar ibar-j"></div><div class="ibody"><span class="itype it-j">Trotar</span><span class="idur">2:00 min</span><div class="ipace-wrap"><span class="ipace sp-g">6:30</span><span class="irange">6:15–6:50</span></div></div></div>
        </div>
        <div class="srow cd"><span class="slabel"><strong>Vuelta a la calma</strong></span><span class="sdur">10 min</span><span class="space sp-g">6:40</span></div>
      </div>
    </div></div>

    <div class="ditem"><div class="dcheck" onclick="td(this)"></div><div class="dbody">
      <div class="dhdr"><span class="dname">Miércoles</span><span class="dtag t-suave">Continuo</span></div>
      <div class="wkwrap">
        <div class="srow wu"><span class="slabel"><strong>Entrada en calor</strong></span><span class="sdur">10 min</span><span class="space sp-g">6:30</span></div>
        <div class="iset"><div class="iset-hdr">3 series</div>
          <div class="irow"><div class="ibar ibar-r"></div><div class="ibody"><span class="itype it-r">Correr</span><span class="idur">5:00 min</span><div class="ipace-wrap"><span class="ipace sp-b">6:00</span><span class="irange">5:50–6:10</span></div></div></div>
          <div class="irow"><div class="ibar ibar-j"></div><div class="ibody"><span class="itype it-j">Trotar</span><span class="idur">3:00 min</span><div class="ipace-wrap"><span class="ipace sp-g">6:30</span><span class="irange">6:15–6:50</span></div></div></div>
        </div>
        <div class="srow run"><span class="slabel"><strong>Continuar suave</strong> hasta 45 min total</span><span class="space sp-g">6:30</span></div>
      </div>
    </div></div>

    <div class="ditem"><div class="dcheck" onclick="td(this)"></div><div class="dbody">
      <div class="dhdr"><span class="dname">Sábado</span><span class="dtag t-fondo">Fondo</span></div>
      <div class="wkwrap">
        <div class="srow run"><span class="slabel"><strong>10 km</strong> continuo</span><span class="space sp-g">6:30</span><span class="srange">6:15–6:50</span></div>
      </div>
    </div></div>

  </div>
</div>

<!-- S2 -->
<div class="wcard" id="w2">
  <div class="whdr" onclick="tw('w2')"><div class="whdr-l"><span class="wnum">Semana 02</span><span class="wpill pill-n">30 mar–4 abr</span></div><span class="wchev">▾</span></div>
  <div class="wdays">

    <div class="ditem"><div class="dcheck" onclick="td(this)"></div><div class="dbody">
      <div class="dhdr"><span class="dname">Lunes</span><span class="dtag t-tempo">Tempo</span></div>
      <div class="wkwrap">
        <div class="srow wu"><span class="slabel"><strong>Entrada en calor</strong></span><span class="sdur">10 min</span><span class="space sp-g">6:30</span></div>
        <div class="iset"><div class="iset-hdr">5 series</div>
          <div class="irow"><div class="ibar ibar-r"></div><div class="ibody"><span class="itype it-r">Correr</span><span class="idur">3:00 min</span><div class="ipace-wrap"><span class="ipace sp-b">5:40</span><span class="irange">5:35–5:45</span></div></div></div>
          <div class="irow"><div class="ibar ibar-j"></div><div class="ibody"><span class="itype it-j">Trotar</span><span class="idur">2:00 min</span><div class="ipace-wrap"><span class="ipace sp-g">6:30</span><span class="irange">suave</span></div></div></div>
        </div>
